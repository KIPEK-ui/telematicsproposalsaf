# Telematics IQ Proposal Generator - Environment Configuration
# Copy this file to .env and fill in your settings

# ========================
# OLLAMA LLM CONFIGURATION
# ========================
# Ollama Base URL - where the LLM API is running
# Default: http://localhost:11434 (Ollama default port)
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM Model - which model to use by default
# Best options based on your Ollama models:
# - llama3.1:8b      (RECOMMENDED: best balance of quality/speed)
# - mistral:7b-instruct (fastest, good instruction following)
# - deepseek-r1:8b   (best reasoning, slower - for extraction)
DEFAULT_LLM_MODEL=llama3.1:8b

# Extraction Model - for requirement extraction (uses more reasoning)
EXTRACTION_LLM_MODEL=deepseek-r1:8b

# Generation Model - for proposal generation (quality over speed)
GENERATION_LLM_MODEL=llama3.1:8b

# ========================
# EMBEDDING CONFIGURATION
# ========================
# Which embedding model to use for RAG (semantic search)
# Default: all-MiniLM-L6-v2 (fast, 384 dimensions)
# Alternatives: all-mpnet-base-v2 (better quality, 768 dimensions)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ========================
# DATABASE CONFIGURATION
# ========================
# Local SQLite database path (relative to project root)
# Database will be created automatically if it doesn't exist
DATABASE_PATH=data/proposals.db

# ========================
# APPLICATION SETTINGS
# ========================
# Proposal generation temperature (0.0-1.0)
# Lower = more deterministic, Higher = more creative
GENERATION_TEMPERATURE=0.3

# Max tokens per proposal section (prevents too-long outputs)
MAX_TOKENS_PER_SECTION=1000

# RAG top-k documents to retrieve (number of past proposals to use as context)
RAG_TOP_K=2

# ========================
# LOGGING CONFIGURATION
# ========================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================
# STREAMLIT CONFIGURATION
# ========================
# Streamlit page layout: wide or centered
STREAMLIT_LAYOUT=wide

# ========================
# DEVELOPMENT/DEBUGGING
# ========================
# Debug mode: true or false
DEBUG=false

# Verbose logging for AI services
VERBOSE_AI_LOGGING=false
